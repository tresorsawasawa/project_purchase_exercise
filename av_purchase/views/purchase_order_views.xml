<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record id="view_purchase_order_form_inherit" model="ir.ui.view">
        <field name="name">purchase.order.form.inherit</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form" />
        <field name="arch" type="xml">
            <!-- Hide the 'Send by Email' button when state is not 'draft' -->
            <xpath expr="//header/button[@name='action_rfq_send']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'Print RFQ' button when state is not 'draft' -->
            <xpath expr="//header/button[@name='print_quotation']" position="attributes">
                <attribute name="invisible">context.get('state') in ('draft', 'sent')</attribute>
            </xpath>

            <!-- Hide the 'Confirm Order' buttons when state is not 'sent' -->
            <xpath expr="//header/button[@id='bid_confirm']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header/button[@id='draft_confirm']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <xpath expr="//header/button[@data-hotkey='k']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>

            <!-- Hide the 'Approve Order' button when state is not 'to approve' -->
            <xpath expr="//header/button[@name='button_approve']" position="attributes">
                <attribute name="invisible">context.get('state') != 'to approve'</attribute>
            </xpath>

            <!-- Ensure 'Cancel' button remains visible in certain states -->
            <xpath expr="//header/button[@name='button_cancel']" position="attributes">
                <attribute name="invisible">context.get('state') not in ('draft', 'to approve',
                    'sent', 'purchase')</attribute>
            </xpath>

            <!-- Make the some fields readonly when the state is not in 'draft' -->
            <xpath expr="//field[@name='order_line']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>

            <xpath expr="//field[@name='date_planned']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>

            <xpath expr="//field[@name='date_order']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>

            <xpath expr="//field[@name='partner_ref']" position="attributes">
                <attribute name="readonly">state != 'draft'</attribute>
            </xpath>

            <!-- Add new buttons inside the header -->
            <xpath expr="//header" position="inside">
                <button name="button_submit" type="object" string="Submit" class="btn btn-primary"
                    invisible="state not in ('draft')" />
                <button name="button_cancel" type="object" string="Cancel" class="btn btn-secondary"
                    invisible="state not in ('draft')" />
            </xpath>
        </field>
    </record>
</odoo>
